[sub_resource type="GDScript" id="GDScript_1rf3o"]
script/source = "extends Control

@onready var line1 = $Line1
@onready var line2 = $Line2
@onready var line3 = $Line3
@onready var fade_overlay = $FadeOverlay

var is_typing = true
var typing_speed = 0.05  # seconds per character
var line_pause = 1.0  # pause after line finishes typing before it disappears
var fade_pause = 0.5  # pause after line disappears before next line starts
var final_pause = 2.0  # pause after last line before transitioning
var fade_duration = 1.0  # how long the fade to black takes

# Store the full text for each line
var line_texts = []

func _ready():
	# Store original text and clear labels
	line_texts = [
		line1.text,
		line2.text,
		line3.text,
	]
	
	# Clear all text and hide lines
	line1.text = \"\"
	line2.text = \"\"
	line3.text = \"\"
	
	line1.visible = false
	line2.visible = false
	line3.visible = false
	
	# Make sure fade overlay starts transparent
	fade_overlay.modulate.a = 0
	
	# Start typing animation
	start_dialogue()

func start_dialogue():
	# Line 1: type, pause, hide
	await type_line(line1, line_texts[0])
	await get_tree().create_timer(line_pause).timeout
	line1.visible = false
	await get_tree().create_timer(fade_pause).timeout
	
	# Line 2: type, pause, hide
	await type_line(line2, line_texts[1])
	await get_tree().create_timer(line_pause).timeout
	line2.visible = false
	await get_tree().create_timer(fade_pause).timeout
	
	# Line 3: type, pause
	await type_line(line3, line_texts[2])
	await get_tree().create_timer(final_pause).timeout
	
	# Fade to black
	await fade_to_black()
	
	# Transition to main game
	print(\"Transitioning to main game\")
	get_tree().change_scene_to_file(\"res://main_game.tscn\")

func fade_to_black():
	var tween = create_tween()
	tween.tween_property(fade_overlay, \"modulate:a\", 1.0, fade_duration)
	await tween.finished

func type_line(label: Label, full_text: String):
	is_typing = true
	label.visible = true
	label.text = \"\"
	
	for i in range(full_text.length()):
		if not is_typing:  # Skip to end if player clicked
			label.text = full_text
			return
		label.text += full_text[i]
		await get_tree().create_timer(typing_speed).timeout
	
	is_typing = false

func _input(event):
	# Allow player to skip typing animation
	if event is InputEventMouseButton and event.pressed:
		if is_typing:
			is_typing = false  # Skip to end of current line
"

